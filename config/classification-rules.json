{
  "$schema": "internal://cs2-config-engine/classification-rules",
  "description": "Reglas de clasificacion por patron de nombre de convar/comando. Se evaluan en orden; gana la primera coincidencia. Patrones en sintaxis .NET regex, insensibles a mayusculas. Anada reglas sin tocar el codigo.",
  "rules": [
    { "category": "P22", "pattern": "^(buy$|buymenu|^slot\\d+_buy)" },
    { "category": "P21", "pattern": "(grenade|molotov|incgrenade|flashbang|smokegrenade|hegrenade|decoy|^use weapon_(flash|smoke|hegrenade|molotov|incgrenade|decoy))" },
    { "category": "P20", "pattern": "(reload|cl_autoreload)" },
    { "category": "P19", "pattern": "(\\+attack|\\+attack2|\\+lookatweapon|drop|cl_silencer|\\+zoom|weapon_)" },
    { "category": "P18", "pattern": "(slot[0-9]+|invnext|invprev|lastinv|switchhands|cl_quickswitch)" },
    { "category": "P25", "pattern": "(cl_crosshair_dynamic|cl_crosshairstyle.*dynamic|cl_crosshair_t)" },
    { "category": "P24", "pattern": "(crosshair|cl_crosshair)" },
    { "category": "P26", "pattern": "(viewmodel)" },
    { "category": "P27", "pattern": "(cl_bob|bob_)" },
    { "category": "P29", "pattern": "(radar|cl_radar|cl_hud_radar)" },
    { "category": "P30", "pattern": "(cl_teamid|cl_show_team|team_)" },
    { "category": "P31", "pattern": "(messagemode|chat|cl_mute)" },
    { "category": "P32", "pattern": "(radio|cl_radio)" },
    { "category": "P33", "pattern": "(voice|\\+voicerecord|cl_mute_enemy_team)" },
    { "category": "P35", "pattern": "(snd_music|music)" },
    { "category": "P36", "pattern": "(mvp)" },
    { "category": "P34", "pattern": "(snd_|volume|dsp_|audio|speaker)" },
    { "category": "P28", "pattern": "(hud|cl_hud|safezonex|safezoney)" },
    { "category": "P37", "pattern": "(spec_|spectator|observer)" },
    { "category": "P38", "pattern": "(demo_|demoui|playdemo)" },
    { "category": "P39", "pattern": "(tv_|gotv)" },
    { "category": "P40", "pattern": "(sv_cheats|sv_infinite|mp_|bot_|sv_grenade|practice)" },
    { "category": "P14", "pattern": "(sensitivity|zoom_sensitivity|m_yaw|m_pitch)" },
    { "category": "P11", "pattern": "(m_raw|m_customaccel|m_mouse|mouse)" },
    { "category": "P12", "pattern": "(key|kbd|keyboard)" },
    { "category": "P13", "pattern": "(joy_|joystick|controller|gamepad|xinput)" },
    { "category": "P16", "pattern": "(\\+jump|cl_autojump)" },
    { "category": "P17", "pattern": "(\\+duck|crouch)" },
    { "category": "P15", "pattern": "(\\+forward|\\+back|\\+left|\\+right|\\+moveleft|\\+moveright|\\+speed|\\+walk|cl_sidespeed|cl_forwardspeed)" },
    { "category": "P10", "pattern": "(input|\\+use|bind)" },
    { "category": "P23", "pattern": "(cash|money|economy|mp_startmoney)" },
    { "category": "P07", "pattern": "(reflex|nvidia)" },
    { "category": "P08", "pattern": "(amd|radeon|fsr)" },
    { "category": "P06", "pattern": "(hdr)" },
    { "category": "P09", "pattern": "(fps_max|frame|fps_pacing|engine_low_latency)" },
    { "category": "P05", "pattern": "(monitor|refresh)" },
    { "category": "P04", "pattern": "(display|fullscreen|windowed|aspectratio|resolution|defaultres)" },
    { "category": "P03", "pattern": "(mat_|video|setting\\.gpu|csm_|shadow)" },
    { "category": "P02", "pattern": "(r_|render)" },
    { "category": "P01", "pattern": "(source2|engine|host_|sv_engine)" },
    { "category": "P41", "pattern": "(net_|rate$|cl_cmdrate|cl_updaterate|cl_interp|mm_|sv_minrate|sv_maxrate)" },
    { "category": "P42", "pattern": "(telemetry|cl_telemetry|stats)" },
    { "category": "P43", "pattern": "(perf|cl_showfps|fps$|cl_detail)" },
    { "category": "P45", "pattern": "(con_|console|toggleconsole|developer$)" },
    { "category": "P46", "pattern": "(debug|cl_debug|r_drawvgui)" },
    { "category": "P44", "pattern": "(cl_|sv_|developer|hud_)" },
    { "category": "P47", "pattern": "(experimental|beta|_test$|_temp$)" },
    { "category": "P00", "pattern": "(setting\\.|cfg_|name$|password|cl_clanid|steam)" }
  ]
}
